HOST=0.0.0.0
PORT=8787
PUBLIC_BASE_URL=https://your-domain.example.com
APPROVAL_SIGNING_SECRET=replace-with-a-long-random-string
ADMIN_ACCESS_TOKEN=replace-with-a-private-admin-password

# Start safely in cloud first, then switch to false after dry-run verification.
DRY_RUN=true
AUTO_EXECUTION_ENABLED=true

# Telegram ingress
TELEGRAM_SOURCE_MODE=bot
TELEGRAM_BOT_TOKEN=123456:replace-me
# TELEGRAM_MODE only applies when TELEGRAM_SOURCE_MODE=bot
TELEGRAM_MODE=webhook
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_USER_SESSION=
TELEGRAM_USER_SESSION_FILE=./data/telegram-user-session.txt

# News chats:
# Get8.Pro = -1003758464445
# Get8.Pro_News = -1003720685651
#
# Analyst chats:
# 舒琴 = -1003093807993
# 零下二度 = -1003358734784
# 易盈社区-所长 = -1002953601978
