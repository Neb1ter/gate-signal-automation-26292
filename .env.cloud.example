TELEGRAM_ALLOWED_CHAT_IDS=-1003758464445,-1003720685651,-1003093807993,-1003358734784,-1002953601978,-1003435926001,-1003162264989,-1003300637347,-1003044946193,-1003547241758
TELEGRAM_ANALYST_CHAT_IDS=-1003093807993,-1003358734784,-1002953601978,-1003435926001,-1003162264989,-1003300637347,-1003044946193,-1003547241758
TELEGRAM_NEWS_CHAT_IDS=-1003758464445,-1003720685651
TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-secret
TELEGRAM_POLL_TIMEOUT_SEC=20
TELEGRAM_CONNECTION_RETRIES=5

# Feishu notifications
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/replace-me

# Optional AI analyst normalization
AI_REVIEW_ENABLED=false
AI_API_KEY=
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=
AI_TIMEOUT_MS=10000

# Gate spot trading
GATE_API_KEY=replace-me
GATE_API_SECRET=replace-me
GATE_BASE_URL=https://api.gateio.ws

# Runtime files
PLAYBOOKS_FILE=./config/playbooks.example.json
DATA_DIR=./data
MAX_DAILY_TRADES=5
MAX_DAILY_NOTIONAL_USD=1000
DEDUP_WINDOW_SEC=1800
